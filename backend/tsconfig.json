{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",                // ✅ must match moduleResolution
    "moduleResolution": "Node16",      // ✅ consistent with module
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}